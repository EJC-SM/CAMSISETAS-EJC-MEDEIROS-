# Copie para .env e preencha com os dados do Firebase.
# Com FIREBASE_DATABASE_URL + FIREBASE_DATABASE_SECRET, `npm run dev` usa o banco real.
# Sem FIREBASE_DATABASE_URL, a API local roda em modo memoria (ideal para testes/E2E).
#
# IMPORTANTE: os dados deste app ficam isolados sob o no raiz `camisetas/` no banco,
# para nao colidir com o app de doacoes que compartilha o mesmo Realtime Database.

# --- Backend (API /api/* — Vercel Functions + dev-server local) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_DATABASE_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Segredos de sessao/admin — GERAR VALORES PROPRIOS DO CAMISETAS.
# NAO reaproveitar os mesmos valores do app de doacoes: como a sessao admin e
# assinada via HMAC com estes segredos, reutiliza-los faria uma sessao de um app
# ser aceita no outro. Gere com: openssl rand -hex 32
ADMIN_API_TOKEN=
SESSION_SECRET=

# Token de uso unico para POST /api/auth/initial-setup (antes do primeiro login).
AUTH_SETUP_TOKEN=
